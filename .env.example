# Villa Campito — variables de entorno
# Copia este archivo a ".env" y rellena los valores.

# --- Base de datos (obligatorio) ---
# Cadena de conexión MySQL. Necesaria para el calendario de días ocupados
# y para las ofertas/promociones del panel de admin.
#
# Si usas docker-compose.yml (ver DEPLOY.md), esta variable se construye
# automáticamente a partir de DB_PASSWORD y puedes dejarla tal cual.
DATABASE_URL=mysql://usuario:contraseña@host:3306/villacampito

# --- Panel de administración (/admin) ---
# Cambia esto por una contraseña propia antes de publicar el sitio.
ADMIN_PASSWORD=Villacampito2023

# --- Servidor ---
# Puerto en el que arranca el servidor (por defecto 3000; si está ocupado
# se prueba con el siguiente disponible).
PORT=3000

# NODE_ENV=production se establece automáticamente al ejecutar "pnpm start"
# tras compilar con "pnpm build". No es necesario definirlo a mano.

# --- Almacenamiento de imágenes subidas (ofertas) ---
# Por defecto, las imágenes que se suben desde /admin se guardan en el disco
# local (carpeta "uploads/" en la raíz del proyecto) y se sirven desde
# /uploads/<archivo>. Esto funciona en cualquier VPS o servidor con disco
# persistente y NO requiere configuración adicional.
#
# UPLOADS_DIR=./uploads

# Si despliegas en una plataforma sin disco persistente (serverless, algunos
# PaaS), puedes usar Amazon S3 en su lugar definiendo estas variables
# (@aws-sdk/client-s3 ya está incluido como dependencia):
#
# S3_BUCKET=mi-bucket-villacampito
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_PUBLIC_URL=https://mi-bucket-villacampito.s3.eu-west-1.amazonaws.com  # opcional, si usas CDN/dominio propio

# --- Analíticas (Umami) — opcional ---
# El sitio incluye el script de Umami Analytics en client/index.html. Si
# tienes tu propia instancia de Umami, define estas dos variables. Con
# docker-compose (ver DEPLOY.md) se pasan automáticamente como build args al
# hacer "docker compose up -d --build". Si no usas Umami, déjalas comentadas
# o elimina el <script> correspondiente en client/index.html.
#
# VITE_ANALYTICS_ENDPOINT=https://analytics.tu-dominio.com
# VITE_ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Docker / Hetzner (ver DEPLOY.md) ---
# Contraseñas para el contenedor MySQL (usadas por docker-compose.yml).
# Genera valores aleatorios, por ejemplo con: openssl rand -hex 16
DB_PASSWORD=cambia-esto-por-algo-aleatorio
DB_ROOT_PASSWORD=cambia-esto-tambien-por-algo-aleatorio

# --- Anthropic (Claude Sonnet para respuestas automáticas de WhatsApp) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Cloudflare R2 (almacenamiento de imágenes en Railway) ---
# Railway no tiene disco persistente, así que las imágenes de ofertas
# se guardan en Cloudflare R2 (compatible con S3, 10 GB gratis).
# Obtén estas credenciales en: dash.cloudflare.com → R2 → Manage R2 API Tokens
S3_BUCKET=villacampito-uploads
AWS_REGION=auto
AWS_ACCESS_KEY_ID=tu-r2-access-key-id
AWS_SECRET_ACCESS_KEY=tu-r2-secret-access-key
# URL pública de tu bucket R2 (actívala en Cloudflare R2 → tu bucket → Settings → Public access)
S3_PUBLIC_URL=https://tu-bucket.tu-cuenta.r2.cloudflarestorage.com
# Endpoint personalizado de R2 (requerido para que el SDK S3 apunte a R2 en vez de AWS)
S3_ENDPOINT=https://tu-account-id.r2.cloudflarestorage.com
